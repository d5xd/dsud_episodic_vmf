	"fadeout" "0.5"
	"fxtime" "0.25"
	"holdtime" "10"
	"message" "Added new versions. Created strange ARGs.\nSometimes someone downloaded the game. Sometimes even launched it."
	"targetname" "writer_dialogue2"
	"x" "-1"
	"y" "0.85"
	"origin" "-8 -8 8"
	editor
	{
