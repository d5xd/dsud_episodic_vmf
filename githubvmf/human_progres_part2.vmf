entity
{
	"id" "108"
	"classname" "game_text"
	"autobreak" "1"
	"channel" "1"
	"color" "255 228 0"
	"color2" "240 110 0"
	"effect" "0"
	"fadein" "1.5"
	"fadeout" "0.5"
	"fxtime" "0.25"
	"holdtime" "10"
	"message" "Nestor... wait. Who am I even talking to? You're here, right? No. Who am I kidding? I knew it all along."
	"targetname" "narrator_monologue"
	"x" "-1"
	"y" "0.85"
	"origin" "-248 -248 8"
	editor
	{
		"color" "220 30 220"
		"visgroupshown" "1"
		"visgroupautoshown" "1"
		"logicalpos" "[0 6500]"
	}
}
