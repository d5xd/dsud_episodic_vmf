	"effect" "0"
	"fadein" "1.5"
	"fadeout" "0.5"
	"fxtime" "0.25"
	"holdtime" "10"
	"message" "Guess what's the funniest thing about this? You weren't planning on playing this damn game.\nYou just saw the page on MODDB."
	"targetname" "narrator_monologue3"
