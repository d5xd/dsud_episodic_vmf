entity
{
	"id" "246"
	"classname" "game_text"
	"autobreak" "1"
	"channel" "1"
	"color" "255 228 0"
	"color2" "240 110 0"
	"effect" "0"
	"fadein" "1.5"
	"fadeout" "0.5"
	"fxtime" "0.25"
	"holdtime" "10"
	"message" "But most often... the page remained silent.\nAnd yet, the developer continued. Not because someone asked, and not because someone was waiting."
	"targetname" "writer_dialogue3"
	"x" "-1"
	"y" "0.85"
	"origin" "8 -8 8"
	editor
	{
