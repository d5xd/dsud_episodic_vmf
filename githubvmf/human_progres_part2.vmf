	"classname" "game_text"
	"autobreak" "1"
	"channel" "1"
	"color" "255 228 0"
	"color2" "240 110 0"
	"effect" "0"
	"fadein" "1.5"
	"fadeout" "0.5"
	"fxtime" "0.25"
	"holdtime" "10"
	"message" "Nestor's just a name. Just a convenient way to talk to you, player."
	"targetname" "narrator_monologue2"
