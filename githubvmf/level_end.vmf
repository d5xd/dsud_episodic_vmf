	"color" "100 100 100"
	"color2" "240 110 0"
	"effect" "0"
	"fadein" "1.5"
	"fadeout" "0.5"
	"fxtime" "0.25"
	"holdtime" "7"
	"message" "So, you ve reached the end. This is the heart of the simulation, where it can be shut down. I wont tell you what to do, but think about it: this worlds been running for eight billion years."
	"targetname" "final1"
	"x" "-1"
	"y" "0.85"
	"origin" "968 -784 12.1769"
